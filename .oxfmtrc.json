{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/*.gen.ts", "**/drizzle/**"],
  "arrowParens": "always",
  "endOfLine": "lf",
  "jsxSingleQuote": false,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "sortImports": true,
  "sortPackageJson": true,
  "sortTailwindcss": {
    "stylesheet": "./src/index.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": true
  }
}
